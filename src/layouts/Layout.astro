---
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Comunidad chilena de Vampire: The Eternal Struggle' } = Astro.props;
const { cspNonce } = Astro.locals;
---

<!doctype html>
<html lang="es" class="bg-night-950 text-night-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — VTES Chile</title>

    <!-- Preconnect para fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Script nonce expuesto al layout para componentes que lo necesiten -->
    <meta name="csp-nonce" content={cspNonce} />
  </head>
  <body class="min-h-screen font-sans antialiased">
    <!-- Header -->
    <header class="border-b border-blood-900/50 bg-night-950/95 backdrop-blur-sm sticky top-0 z-50">
      <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-blood-500 text-2xl font-serif font-bold tracking-widest group-hover:text-blood-400 transition-colors">
            VTES
          </span>
          <span class="text-night-300 text-sm font-medium hidden sm:inline">Chile</span>
        </a>
        <ul class="flex items-center gap-6 text-sm font-medium text-night-300">
          <li><a href="/torneos" class="hover:text-gold-400 transition-colors">Torneos</a></li>
          <li><a href="/decks" class="hover:text-gold-400 transition-colors">Decks</a></li>
          <li><a href="/blog" class="hover:text-gold-400 transition-colors">Noticias</a></li>
          <li><a href="/comunidad" class="hover:text-gold-400 transition-colors">Comunidad</a></li>
        </ul>
      </nav>
    </header>

    <!-- Contenido principal -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-night-800 mt-24 py-10 text-center text-night-500 text-sm">
      <p class="font-serif tracking-wide text-blood-700">
        Vampire: The Eternal Struggle
      </p>
      <p class="mt-1">
        Comunidad chilena — Mundo de Tinieblas &trade; Paradox Interactive
      </p>
      <p class="mt-2 text-night-700 text-xs">
        Sitio fan no oficial. Las cartas y la ambientación pertenecen a sus respectivos titulares.
      </p>
    </footer>
  </body>
</html>
