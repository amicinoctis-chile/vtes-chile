---
import Font from 'astro/components/Font.astro';
import '@/styles/global.css';
import Footer from '@/components/global/Footer.astro';
import Logo from '@/assets/logo-vtes-chile.svg'

interface Props {
  /** Título de la página (se añade "— VTES Chile" automáticamente) */
  title: string;
  /** Descripción para meta description y OG:description */
  description?: string;
  /** Ruta o URL absoluta de la imagen OG. Default: /og-default.png */
  ogImage?: string;
  /** Tipo de objeto OG. Default: 'website' */
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Comunidad chilena de Vampire: The Eternal Struggle — eventos, ligas, noticias y más.',
  ogImage = '/og-default.png',
  ogType = 'website',
} = Astro.props;

const { cspNonce } = Astro.locals;

const pageTitle = `${title} — VTES Chile`;
const canonicalUrl = Astro.url.href;
const ogImageUrl = new URL(ogImage, Astro.url.origin).href;

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/events', label: 'Eventos' },
  { href: '/leagues', label: 'Ligas' },
  { href: '/stores', label: 'Tiendas' },
  { href: '/sites', label: 'Comunidad' },
  { href: '/blog', label: 'Blog' },
  { href: '/decks', label: 'Decks' },
  { href: '/contact', label: 'Contacto' },
] as const;

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<!doctype html>
<html lang="es" class="bg-night-950 text-night-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph — Discord y WhatsApp leen estas etiquetas para generar previews -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:site_name" content="VTES Chile" />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter Card (Discord también lo usa para embeds) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- CSP nonce accesible para componentes que necesiten scripts inline -->
    <meta name="csp-nonce" content={cspNonce} />

    <!-- Fuentes via Astro Fonts API — descargadas y auto-hosteadas en build -->
    <Font cssVariable="--font-cinzel" preload />
    <Font cssVariable="--font-inter" />
  </head>

  <body class="min-h-screen font-sans antialiased">

    <!-- ═══════════════════════════ HEADER ═══════════════════════════ -->
    <header class="sticky top-0 z-50 border-b border-night-800/60 bg-night-950/95 backdrop-blur-sm">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <nav class="flex items-center justify-between h-16" aria-label="Navegación principal">

          <!-- Logo -->
          <a href="/" class="flex items-center shrink-0 group" aria-label="VTES Chile — Inicio">
            <Logo width=auto height={12} fill="currentColor"/>
          </a>

          <!-- Links de escritorio -->
          <ul class="hidden md:flex items-center gap-1 text-sm font-medium" role="list">
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  aria-current={isActive(href) ? 'page' : undefined}
                  class:list={[
                    'px-3 py-2 rounded-sm transition-colors',
                    isActive(href)
                      ? 'text-gold-400 font-semibold'
                      : 'text-night-300 hover:text-gold-400',
                  ]}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>

          <!-- Botón hamburguesa (mobile) -->
          <button
            id="nav-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="nav-menu"
            aria-label="Abrir menú de navegación"
            class="md:hidden p-2 text-night-400 hover:text-night-100 transition-colors rounded-sm"
          >
            <svg
              id="icon-menu"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-6 h-6"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            <svg
              id="icon-close"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-6 h-6 hidden"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>

        </nav>
      </div>

      <!-- Menú móvil desplegable -->
      <div
        id="nav-menu"
        class="hidden md:hidden border-t border-night-800/60 bg-night-950"
        role="navigation"
        aria-label="Menú móvil"
      >
        <ul class="mx-auto max-w-7xl px-4 py-3 flex flex-col gap-0.5" role="list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                aria-current={isActive(href) ? 'page' : undefined}
                class:list={[
                  'block px-3 py-2.5 rounded-sm text-sm font-medium transition-colors',
                  isActive(href)
                    ? 'text-gold-400 bg-night-900'
                    : 'text-night-300 hover:text-night-100 hover:bg-night-900',
                ]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <Footer /> 

    <!-- Toggle del menú móvil (nonce permite el script inline con CSP) -->
    <script nonce={cspNonce}>
      const toggle = document.getElementById('nav-toggle');
      const menu = document.getElementById('nav-menu');
      const iconMenu = document.getElementById('icon-menu');
      const iconClose = document.getElementById('icon-close');

      toggle?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', isOpen);
        iconMenu?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
        toggle.setAttribute('aria-expanded', String(!isOpen));
      });
    </script>

  </body>
</html>
