---
import Font from 'astro/components/Font.astro';
import '@/styles/global.css';
import Header from '@/components/global/Header.astro';
import Footer from '@/components/global/Footer.astro';
import JsonLd from '@/components/ui/JsonLd.astro';

interface Props {
  /** Título de la página (se añade "— VTES Chile" automáticamente) */
  title: string;
  /** Descripción para meta description y OG:description */
  description?: string;
  /** Ruta o URL absoluta de la imagen OG. Default: /og-default.png */
  ogImage?: string;
  /** Tipo de objeto OG. Default: 'website' */
  ogType?: 'website' | 'article';
  /** Fecha de publicación ISO para artículos */
  publishedTime?: string;
  /** Fecha de modificación ISO para artículos */
  modifiedTime?: string;
}

const {
  title,
  description = 'Comunidad chilena de Vampire: The Eternal Struggle — eventos, ligas, noticias y más.',
  ogImage = '/og-default.png',
  ogType = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const { cspNonce } = Astro.locals;

const pageTitle = `${title} — VTES Chile`;
const canonicalUrl = Astro.url.href;
const ogImageUrl = new URL(ogImage, Astro.url.origin).href;
---

<!doctype html>
<html lang="es" class="bg-night-950 text-marfil-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="VTES Chile — Blog" href="/rss.xml" />

    <!-- Open Graph — Discord y WhatsApp leen estas etiquetas para generar previews -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:site_name" content="VTES Chile" />
    <meta property="og:locale" content="es_CL" />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}

    <!-- Twitter Card (Discord también lo usa para embeds) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- CSP nonce accesible para componentes que necesiten scripts inline -->
    <meta name="csp-nonce" content={cspNonce} />

    <!-- Fuentes via Astro Fonts API — descargadas y auto-hosteadas en build -->
    <Font cssVariable="--font-cinzel" preload />
    <Font cssVariable="--font-inter" />

    <JsonLd data={{
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'VTES Chile',
      url: 'https://vtes.cl',
      logo: 'https://vtes.cl/og-default.png',
    }} />
    <slot name="head" />
  </head>

  <body class="min-h-screen font-sans antialiased">

    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:bg-blood-700 focus:text-marfil-50 focus:px-4 focus:py-2 focus:rounded-sm">
      Saltar al contenido
    </a>

    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer /> 

    <!-- Toggle del menú móvil (nonce permite el script inline con CSP) -->
    <script nonce={cspNonce}>
      const toggle = document.getElementById('nav-toggle');
      const menu = document.getElementById('nav-menu');
      const iconMenu = document.getElementById('icon-menu');
      const iconClose = document.getElementById('icon-close');

      toggle?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', isOpen);
        iconMenu?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
        toggle.setAttribute('aria-expanded', String(!isOpen));
      });
    </script>

  </body>
</html>
