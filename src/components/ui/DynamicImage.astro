---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  folder: 'blogs' | 'events' | 'sites';
  img?: string;
  alt: string;
  class?: string;
}

const { folder, img, alt, class: className } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpg,jpeg,png,webp}"
);

const defaultPath = `/src/assets/${folder}/default.jpg`;

let loader = images[defaultPath];

if (img) {
  const imagePath = `/src/assets/${folder}/${img}`;
  if (images[imagePath]) {
    loader = images[imagePath];
  }
}

if (!loader) {
  throw new Error(
    `No se encontró la imagen por defecto en ${defaultPath}. Asegúrate de que el archivo existe.`
  );
}

const resolved = (await loader()).default;
---

<Image src={resolved} alt={alt} class={className} loading="lazy" />
