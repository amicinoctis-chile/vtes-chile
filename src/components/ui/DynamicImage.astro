---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  folder: 'blogs' | 'events' | 'sites';
  img?: string;
  alt: string;
  class?: string;
  priority?: boolean;
}

const { folder, img, alt, class: className, priority = false } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpg,jpeg,png,webp}"
);

const defaultPath = `/src/assets/${folder}/default.jpg`;

let loader = images[defaultPath];

if (img) {
  const imagePath = `/src/assets/${folder}/${img}`;
  if (images[imagePath]) {
    loader = images[imagePath];
  }
}

if (!loader) {
  throw new Error(
    `No se encontró la imagen por defecto en ${defaultPath}. Asegúrate de que el archivo existe.`
  );
}

const resolved = (await loader()).default;
---

<Image
  src={resolved}
  alt={alt}
  class={className}
  widths={[640, 960, 1280]}
  sizes="(min-width: 1024px) 1024px, 100vw"
  format="webp"
  quality={80}
  loading={priority ? 'eager' : 'lazy'}
  fetchpriority={priority ? 'high' : 'auto'}
/>
