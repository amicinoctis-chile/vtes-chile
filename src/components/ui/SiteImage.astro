---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  img?: string;
  alt: string;
  class?: string;
}

const { img, alt, class: className } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/sites/*.{jpg,jpeg,png,webp}"
);

const defaultPath = "/src/assets/sites/default.jpg";

let loader = images[defaultPath];

if (img) {
  const imagePath = `/src/assets/sites/${img}`;
  if (images[imagePath]) {
    loader = images[imagePath];
  }
}

if (!loader) {
  throw new Error(
    `No se encontró la imagen por defecto en ${defaultPath}. Asegúrate de que el archivo existe.`
  );
}

const resolved = (await loader()).default;
---

<Image src={resolved} alt={alt} class={className} />