---
import Logo from '@/assets/logo-vtes-chile.svg'

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/events', label: 'Eventos' },
  { href: '/leagues', label: 'Ligas' },
  { href: '/stores', label: 'Tiendas' },
  { href: '/sites', label: 'Comunidad' },
  { href: '/blog', label: 'Blog' },
  { href: '/decks', label: 'Decks' },
  { href: '/contact', label: 'Contacto' },
] as const;

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---
<header class="sticky top-0 z-50 border-b border-night-800/60 bg-night-950/95 backdrop-blur-sm">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <nav class="flex items-center justify-between h-16" aria-label="Navegación principal">

          <!-- Logo -->
          <a href="/" class="flex items-center shrink-0 group" aria-label="VTES Chile — Inicio">
            <Logo fill="currentColor"/>
          </a>

          <!-- Links de escritorio -->
          <ul class="hidden md:flex items-center gap-1 text-sm font-medium" role="list">
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  aria-current={isActive(href) ? 'page' : undefined}
                  class:list={[
                    'px-3 py-2 rounded-sm transition-colors',
                    isActive(href)
                      ? 'text-blood-500 font-semibold'
                      : 'text-marfil-300 hover:text-blood-500',
                  ]}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>

          <!-- Botón hamburguesa (mobile) -->
          <button
            id="nav-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="nav-menu"
            aria-label="Abrir menú de navegación"
            class="md:hidden p-2 text-marfil-400 hover:text-marfil-100 transition-colors rounded-sm"
          >
            <svg
              id="icon-menu"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-6 h-6"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            <svg
              id="icon-close"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-6 h-6 hidden"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>

        </nav>
      </div>

      <!-- Menú móvil desplegable -->
      <div
        id="nav-menu"
        class="hidden md:hidden border-t border-night-800/60 bg-night-950"
        role="navigation"
        aria-label="Menú móvil"
      >
        <ul class="mx-auto max-w-7xl px-4 py-3 flex flex-col gap-0.5" role="list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                aria-current={isActive(href) ? 'page' : undefined}
                class:list={[
                  'block px-3 py-2.5 rounded-sm text-sm font-medium transition-colors',
                  isActive(href)
                    ? 'text-blood-500 bg-night-900'
                    : 'text-marfil-300 hover:text-blood-500 hover:bg-night-900',
                ]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>