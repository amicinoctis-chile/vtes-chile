---
import { Image } from 'astro:assets';
import HeroImage from '@/assets/hero-image.jpg';
---

<section class="relative overflow-hidden min-h-150">
  <div class="grid grid-cols-1 md:grid-cols-2 min-h-150">

    <!-- Columna izquierda: texto -->
    <div class="relative flex items-center z-10">

      <div class="w-full px-6 md:px-10 lg:px-16 py-20 md:py-16 relative">
        <h1 class="font-serif text-3xl lg:text-5xl xl:text-6xl font-bold text-marfil-50 leading-tight">
          Vampire:<br />
          <span class="text-blood-600">The Eternal Struggle</span>
        </h1>
        <p class="mt-4 text-lg text-marfil-300 max-w-md">
          Comunidad Chilena de Vampire: the Eternal Struggle
        </p>
      </div>
    </div>

    <!-- Columna derecha: imagen -->
    <div class="absolute inset-0 md:relative md:flex md:items-center md:justify-center md:bg-night-950">
      <Image
        src={HeroImage}
        alt="Vampire alimentandose en un callejon - Arte de Vampiro La Mascarada"
        class="w-full h-full object-cover object-top md:object-contain"
      />
      <!-- Degradado lateral desktop: funde imagen con columna izquierda -->
      <div class="absolute inset-0 bg-linear-to-r from-night-950 via-transparent to-transparent pointer-events-none hidden md:block"></div>
      <!-- Overlay mobile: mejora contraste del texto sobre la imagen -->
      <div class="absolute inset-0 bg-night-950/60 pointer-events-none md:hidden"></div>
    </div>

  </div>
</section>
