---
import { Image } from 'astro:assets';
import HeroImage from '@/assets/hero-image.jpg';
---

<section class="relative overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-2">
    <div class="relative flex items-center z-10">
      <div class="absolute inset-0 h-24 bg-gradient-to-b from-black via-transparent to-transparent md:hidden pointer-events-none"></div>
      <div class="w-full px-6 md:px-10 lg:px-16 py-16 md:py-0 relative">
        <div class="max-w-xl text-white">
          <h1 class="font-serif text-3xl lg:text-5xl font-bold text-night-50 leading-tight">
            Vampire:<br />
            <span class="text-blood-500">The Eternal Struggle</span>
          </h1>
          <p class="mt-6 text-xl text-night-100 max-w-2xl mx-auto">
            Comunidad Chilena de Vampire: the Eternal Struggle
          </p>
        </div>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 hidden">
          <a
            href="/events"
            class="inline-flex items-center justify-center px-7 py-3 bg-blood-700 hover:bg-blood-600 text-night-50 font-semibold rounded-sm transition-colors"
          >
            Ver Eventos
          </a>
          <a
            href="/comunidad"
            class="inline-flex items-center justify-center px-7 py-3 border border-night-700 hover:border-night-500 text-night-200 font-semibold rounded-sm transition-colors"
          >
            Ver Sitios de la Comunidad
          </a>
        </div>
      </div>
    </div>

    <div class="absolute inset-0 md:relative md:min-h-full">
      <Image
        src={HeroImage}
        alt="Vampire alimentandose en un callejon - Arte de Vampiro La Mascarada"
      />
      <div class="absolute bottom-0 inset-x-0 h-48 bg-gradient-to-t from-black to-transparent z-10 md:pointer-events-none"></div>
      <div class="absolute inset-0 bg-black/50 md:hidden pointer-events-none"></div>
      <div class="absolute inset-0 bg-gradient-to-l from-transparent via-transparent to-black/60 pointer-events-none"></div>
    </div>
  </div>

  <div class="pointer-events-none absolute inset-y-0 left-1/2 hidden w-48 -translate-x-1/2 md:block bg-gradient-to-r from-transparent via-black/100 to-transparent"></div>
</section>
