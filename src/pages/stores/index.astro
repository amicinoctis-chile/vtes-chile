---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const ciudadParam = Astro.url.searchParams.get('ciudad') ?? '';

const allStores = await getCollection('stores');

const cities = [...new Set(allStores.map(s => s.data.city))].sort();

let stores = ciudadParam
  ? allStores.filter(s => s.data.city.toLowerCase() === ciudadParam.toLowerCase())
  : [...allStores];

stores.sort((a, b) => {
  const cityDiff = a.data.city.localeCompare(b.data.city, 'es');
  return cityDiff !== 0 ? cityDiff : a.data.name.localeCompare(b.data.name, 'es');
});
---

<BaseLayout
  title="Tiendas"
  description="Tiendas donde se juega Vampire: The Eternal Struggle en Chile."
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">

    <header class="mb-10">
      <h1 class="font-serif text-4xl font-bold text-night-50">Tiendas</h1>
      <p class="mt-2 text-night-400">Lugares donde se juega Vampire: The Eternal Struggle en Chile.</p>
    </header>

    <!-- Filtro por ciudad -->
    <form method="GET" class="mb-10 flex flex-wrap items-end gap-4">
      <div class="flex flex-col gap-1">
        <label for="ciudad-select" class="text-xs text-night-500 font-medium uppercase tracking-wide">
          Ciudad
        </label>
        <select
          id="ciudad-select"
          name="ciudad"
          class="bg-night-900 border border-night-700 text-night-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-blood-600"
        >
          <option value="">Todas las ciudades</option>
          {cities.map(c => (
            <option value={c} selected={ciudadParam.toLowerCase() === c.toLowerCase()}>{c}</option>
          ))}
        </select>
      </div>
      <div class="flex items-end gap-3">
        <button
          type="submit"
          class="px-4 py-2 bg-blood-700 hover:bg-blood-600 text-night-50 text-sm font-semibold rounded-sm transition-colors"
        >
          Filtrar
        </button>
        {ciudadParam && (
          <a
            href="/stores"
            class="px-4 py-2 text-sm text-night-400 hover:text-night-200 transition-colors"
          >
            Limpiar
          </a>
        )}
      </div>
    </form>

    <!-- Grid de tiendas -->
    {stores.length > 0 ? (
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {stores.map(store => (
          <li>
            <article class="border border-night-800 bg-night-900/50 rounded-sm p-5 hover:border-blood-800 transition-colors flex flex-col gap-3 h-full">
              <div>
                <h2 class="text-night-100 font-semibold text-lg">{store.data.name}</h2>
                <p class="text-sm text-night-400 mt-1">{store.data.location}</p>
                <span class="inline-block mt-2 text-xs text-night-500 border border-night-800 rounded-sm px-2 py-0.5">
                  {store.data.city}
                </span>
              </div>
              <div class="flex flex-wrap gap-3 mt-auto">
                {store.data.url && (
                  <a
                    href={store.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-blood-500 hover:text-blood-400 transition-colors font-medium"
                  >
                    Sitio web ↗
                  </a>
                )}
                {store.data.instagram && (
                  <a
                    href={store.data.instagram}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-blood-500 hover:text-blood-400 transition-colors font-medium"
                  >
                    Instagram ↗
                  </a>
                )}
                {store.data.whatsapp && (
                  <a
                    href={store.data.whatsapp}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-blood-500 hover:text-blood-400 transition-colors font-medium"
                  >
                    WhatsApp ↗
                  </a>
                )}
              </div>
            </article>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-night-500 py-12 text-center">
        No hay tiendas{ciudadParam ? ` en ${ciudadParam}` : ''} registradas.
      </p>
    )}

  </div>
</BaseLayout>
