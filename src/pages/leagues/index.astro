---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Pagination from '@/components/ui/Pagination.astro';
import AutoSubmitFilters from '@/components/ui/AutoSubmitFilters.astro';
import { getCollection } from 'astro:content';
import { formatCLP, proxyLabel, capitalize, MONTH_NAMES, isLeagueFinished } from '@/lib/format';

const mesParam = Astro.url.searchParams.get('mes') ?? '';
const añoParam = Astro.url.searchParams.get('año') ?? '';
const formatoParam = Astro.url.searchParams.get('formato') ?? '';
const estadoParam = Astro.url.searchParams.get('estado') ?? 'activas';
const paginaParam = parseInt(Astro.url.searchParams.get('pagina') ?? '1', 10);
const PER_PAGE = 9;

const validFormats = ['V5', 'standard', 'storyline', 'limited', 'casual'] as const;
type LeagueFormat = typeof validFormats[number];

const validEstados = ['activas', 'finalizadas', 'todas'] as const;
type Estado = typeof validEstados[number];
const estado: Estado = (validEstados as readonly string[]).includes(estadoParam)
  ? (estadoParam as Estado)
  : 'activas';

const dayOrder = ['lunes','martes','miércoles','jueves','viernes','sábado','domingo'];

// Guardar colección completa para calcular años únicos antes de filtrar
const allLeaguesRaw = await getCollection('leagues');
const allYears = [...new Set(allLeaguesRaw.map(l => l.data.year))].sort((a, b) => a - b);

let allLeagues = [...allLeaguesRaw];

// Filtro por mes
const mesNum = parseInt(mesParam, 10);
if (mesParam && !isNaN(mesNum)) {
  allLeagues = allLeagues.filter(l => l.data.month === mesNum);
}

// Filtro por año
const añoNum = parseInt(añoParam, 10);
if (añoParam && !isNaN(añoNum)) {
  allLeagues = allLeagues.filter(l => l.data.year === añoNum);
}

// Filtro por formato
if (validFormats.includes(formatoParam as LeagueFormat)) {
  allLeagues = allLeagues.filter(l => l.data.format === formatoParam);
}

// Filtro por estado
if (estado === 'activas') {
  allLeagues = allLeagues.filter(l => !isLeagueFinished(l.data));
} else if (estado === 'finalizadas') {
  allLeagues = allLeagues.filter(l => isLeagueFinished(l.data));
}

// Ordenar: cuando son finalizadas, más recientes primero
const sortDir = estado === 'finalizadas' ? -1 : 1;
allLeagues.sort((a, b) => {
  if (a.data.year !== b.data.year) return (a.data.year - b.data.year) * sortDir;
  if (a.data.month !== b.data.month) return (a.data.month - b.data.month) * sortDir;
  return dayOrder.indexOf(a.data.day) - dayOrder.indexOf(b.data.day);
});

const totalPages = Math.max(1, Math.ceil(allLeagues.length / PER_PAGE));
const page = Math.min(Math.max(1, paginaParam), totalPages);
const leagues = allLeagues.slice((page - 1) * PER_PAGE, page * PER_PAGE);

const hasActiveFilters = mesParam !== '' || añoParam !== '' || formatoParam !== '' || estado !== 'activas';

const buildPageUrl = (p: number) => {
  const params = new URLSearchParams();
  if (mesParam) params.set('mes', mesParam);
  if (añoParam) params.set('año', añoParam);
  if (formatoParam) params.set('formato', formatoParam);
  if (estado !== 'activas') params.set('estado', estado);
  if (p > 1) params.set('pagina', String(p));
  const qs = params.toString();
  return `/leagues${qs ? '?' + qs : ''}`;
};
---

<BaseLayout
  title="Ligas"
  description="Ligas recurrentes de Vampire: The Eternal Struggle en Chile."
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">

    <header class="mb-10">
      <h1 class="font-serif text-4xl font-bold text-marfil-50">Ligas</h1>
      <p class="mt-2 text-marfil-400">Ligas recurrentes de VTES en Chile.</p>
    </header>

    <!-- Filtros -->
    <form id="filters-form" method="GET" class="mb-10 flex flex-wrap items-end gap-4">

      <!-- Estado -->
      <div class="flex flex-col gap-1">
        <span class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Estado</span>
        <div class="flex items-center gap-4 px-3 py-2 text-sm text-marfil-200">
          <label class="flex items-center gap-2">
            <input type="radio" name="estado" value="activas" checked={estado === 'activas'} class="accent-blood-600" />
            Activas
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="estado" value="finalizadas" checked={estado === 'finalizadas'} class="accent-blood-600" />
            Finalizadas
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="estado" value="todas" checked={estado === 'todas'} class="accent-blood-600" />
            Todas
          </label>
        </div>
      </div>

      <!-- Mes -->
      <div class="flex flex-col gap-1">
        <label for="mes-select" class="text-xs text-marfil-500 font-medium uppercase tracking-wide">
          Mes
        </label>
        <select
          id="mes-select"
          name="mes"
          class="bg-night-900 border border-night-700 text-marfil-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-blood-600"
        >
          <option value="">Todos los meses</option>
          {MONTH_NAMES.slice(1).map((name, i) => (
            <option value={i + 1} selected={mesParam === String(i + 1)}>{name}</option>
          ))}
        </select>
      </div>

      <!-- Año -->
      <div class="flex flex-col gap-1">
        <label for="año-select" class="text-xs text-marfil-500 font-medium uppercase tracking-wide">
          Año
        </label>
        <select
          id="año-select"
          name="año"
          class="bg-night-900 border border-night-700 text-marfil-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-blood-600"
        >
          <option value="">Todos los años</option>
          {allYears.map(y => (
            <option value={y} selected={añoParam === String(y)}>{y}</option>
          ))}
        </select>
      </div>

      <!-- Formato -->
      <div class="flex flex-col gap-1">
        <label for="formato-select" class="text-xs text-marfil-500 font-medium uppercase tracking-wide">
          Formato
        </label>
        <select
          id="formato-select"
          name="formato"
          class="bg-night-900 border border-night-700 text-marfil-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-blood-600"
        >
          <option value="">Todos los formatos</option>
          {validFormats.map(f => (
            <option value={f} selected={formatoParam === f}>{capitalize(f)}</option>
          ))}
        </select>
      </div>

      <!-- Acciones -->
      <div class="flex items-end gap-3">
        <Button type="submit" size="sm" data-filter-submit>Filtrar</Button>
        {hasActiveFilters && (
          <a
            href="/leagues"
            class="px-4 py-2 text-sm text-marfil-400 hover:text-marfil-200 transition-colors"
          >
            Limpiar filtros
          </a>
        )}
      </div>

    </form>

    <!-- Grid de ligas -->
    {leagues.length > 0 ? (
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {leagues.map(league => {
          const finalizada = isLeagueFinished(league.data);
          return (
            <li>
              <article class:list={[
                'group relative border border-night-800 bg-night-900/50 rounded-sm p-5 hover:border-blood-800 transition-colors flex flex-col gap-2 h-full',
                finalizada && 'opacity-60',
              ]}>
                <a
                  href={`/leagues/${league.id}`}
                  class="absolute inset-0 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-blood-600"
                  aria-label={league.data.title}
                ></a>
                <div class="flex items-center justify-between gap-2">
                  <span class="text-xs text-blood-500 font-medium tracking-wide uppercase">
                    {league.data.day} · {league.data.hour}
                  </span>
                  <div class="flex items-center gap-2">
                    {finalizada && (
                      <span class="text-[10px] uppercase tracking-wide px-2 py-0.5 rounded-sm bg-night-800 text-marfil-400 border border-night-700">
                        Finalizada
                      </span>
                    )}
                    <span class="text-xs text-marfil-500">
                      {MONTH_NAMES[league.data.month]} {league.data.year}
                    </span>
                  </div>
                </div>
                <h2 class="text-marfil-100 font-semibold leading-snug group-hover:text-blood-600 transition-colors">
                  {league.data.title}
                </h2>
                <p class="text-sm text-marfil-400">{league.data.city} · {league.data.format}</p>
                <p class="text-sm font-medium text-gold-500">{formatCLP(league.data.entryFee)}</p>
                <p class="text-xs text-marfil-500">Proxies: {proxyLabel(league.data.proxyesAllowed)}</p>
              </article>
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="text-marfil-500 py-12 text-center">
        No hay ligas {estado === 'activas' ? 'activas' : estado === 'finalizadas' ? 'finalizadas' : ''}
        {mesParam && !isNaN(mesNum) ? ` en ${MONTH_NAMES[mesNum]}` : ''}
        {añoParam ? ` ${añoParam}` : ''}
        {formatoParam ? ` con formato ${formatoParam}` : ''}.
      </p>
    )}

    <Pagination page={page} totalPages={totalPages} buildUrl={buildPageUrl} />

  </div>

  <AutoSubmitFilters formId="filters-form" />
</BaseLayout>
