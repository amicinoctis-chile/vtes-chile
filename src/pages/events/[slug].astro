---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { getEntry, render } from 'astro:content';
import DynamicImage from '@/components/ui/DynamicImage.astro';
import JsonLd from '@/components/ui/JsonLd.astro';
import { formatCLP, formatDateLong, formatEventSchedule, proxyLabel } from '@/lib/format';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/events');

const entry = await getEntry('events', slug);
if (!entry) return new Response(null, { status: 404, statusText: 'Not Found' });

const event = entry.data;

const today = new Date();
today.setHours(0, 0, 0, 0);
const eventDate = new Date(event.startDate + 'T12:00:00');
const isFuture = eventDate >= today;
const isPast = eventDate < today;
const isMultiDay = event.endDate !== event.startDate;


const { Content } = await render(entry);
---

<BaseLayout
  title={event.title}
  description={event.description}
  ogType="article"
>
  <JsonLd slot="head" data={{
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: event.title,
    description: event.description,
    startDate: `${event.startDate}T${event.startTime}:00`,
    endDate: `${event.endDate}T${event.endTime}:00`,
    location: {
      '@type': 'Place',
      name: event.location,
      address: { '@type': 'PostalAddress', addressLocality: event.city, addressCountry: 'CL' },
    },
    organizer: { '@type': 'Organization', name: event.organizer },
    ...(event.entryFee > 0 && {
      offers: {
        '@type': 'Offer',
        price: event.entryFee,
        priceCurrency: 'CLP',
      },
    }),
  }} />
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-marfil-500">
      <a href="/events" class="hover:text-marfil-300 transition-colors">Eventos</a>
      <span class="mx-2">/</span>
      <span class="text-marfil-300">{event.title}</span>
    </nav>

    <!-- Cabecera -->
    <header class="mb-10">
      <p class="text-xs text-blood-500 font-medium tracking-wide uppercase mb-2">
        {formatDateLong(event.startDate)} · {event.startTime}
        {isMultiDay && <> — {formatDateLong(event.endDate)} · {event.endTime}</>}
      </p>
      <h1 class="font-serif text-4xl lg:text-5xl font-bold text-marfil-50 leading-tight">
        {event.title}
      </h1>
      <p class="mt-4 text-lg text-marfil-300">{event.description}</p>
    </header>

    <!-- Imagen del evento -->
    <DynamicImage
      folder="events"
      img={event.img}
      alt={event.title}
      class=""
    />

    <!-- Grid de detalles -->
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-5 border border-night-800 rounded-sm p-6 bg-night-900/30 mb-10">
      {!isMultiDay && (
        <div>
          <dt class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Fecha</dt>
          <dd class="mt-1 text-marfil-100">{formatDateLong(event.startDate)}</dd>
        </div>
      )}
      <div>
        <dt class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Horario</dt>
        <dd class="mt-1 text-marfil-100">
          {formatEventSchedule(event.startDate, event.startTime, event.endDate, event.endTime)}
        </dd>
      </div>
      <div>
        <dt class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Lugar</dt>
        <dd class="mt-1 text-marfil-100">{event.location}</dd>
      </div>
      <div>
        <dt class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Ciudad</dt>
        <dd class="mt-1 text-marfil-100">{event.city}</dd>
      </div>
      <div>
        <dt class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Formato</dt>
        <dd class="mt-1 text-marfil-100 capitalize">{event.format}</dd>
      </div>
      <div>
        <dt class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Rondas</dt>
        <dd class="mt-1 text-marfil-100">{event.rounds} + Final</dd>
      </div>
      <div>
        <dt class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Entrada</dt>
        <dd class="mt-1 text-marfil-100">{formatCLP(event.entryFee)}</dd>
      </div>
      <div>
        <dt class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Proxies</dt>
        <dd class="mt-1 text-marfil-100">{proxyLabel(event.proxyesAllowed)}</dd>
      </div>
      <div>
        <dt class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Organizador</dt>
        <dd class="mt-1 text-marfil-100">{event.organizer}</dd>
      </div>
      {event.maxPlayers && (
        <div>
          <dt class="text-xs text-marfil-500 font-medium uppercase tracking-wide">Jugadores máx.</dt>
          <dd class="mt-1 text-marfil-100">{event.maxPlayers}</dd>
        </div>
      )}
    </dl>

    <!-- CTAs condicionales -->
    <div class="flex flex-wrap gap-4 mb-10">
      {isFuture && event.registrationUrl && (
        <Button href={event.registrationUrl} target="_blank">
          Inscribirse al evento ↗
        </Button>
      )}
      {isPast && event.resultsUrl && (
        <Button href={event.resultsUrl} target="_blank" variant="outline">
          Ver resultados ↗
        </Button>
      )}
    </div>

    <!-- Contenido markdown -->
    {entry.body && (
      <div class="mt-10 prose prose-invert prose-sm max-w-none">
        <Content />
      </div>
    )}

    <!-- Volver -->
    <div class="mt-16 pt-8 border-t border-night-900">
      <a
        href="/events"
        class="text-sm text-blood-500 hover:text-blood-400 transition-colors"
      >
        ← Volver a eventos
      </a>
    </div>

  </div>
</BaseLayout>
