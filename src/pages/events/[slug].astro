---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import EventImage from '@/components/ui/EventImage.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/events');

const entry = await getEntry('events', slug);
if (!entry) return new Response(null, { status: 404, statusText: 'Not Found' });

const event = entry.data;

const today = new Date();
today.setHours(0, 0, 0, 0);
const eventDate = new Date(event.date + 'T12:00:00');
const isFuture = eventDate >= today;
const isPast = eventDate < today;

const formatCLP = (n: number) =>
  n === 0 ? 'Gratuito' : n.toLocaleString('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });

const formatDate = (s: string) =>
  new Date(s + 'T12:00:00').toLocaleDateString('es-CL', { dateStyle: 'long' });

const proxyLabel = (v: string) =>
  v === 'si' ? 'Sí' : v === 'no' ? 'No' : 'Por confirmar';

const { Content } = await render(entry);
---

<BaseLayout
  title={event.title}
  description={event.description}
  ogType="article"
>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-night-500">
      <a href="/events" class="hover:text-night-300 transition-colors">Eventos</a>
      <span class="mx-2">/</span>
      <span class="text-night-300">{event.title}</span>
    </nav>

    <!-- Cabecera -->
    <header class="mb-10">
      <p class="text-xs text-blood-500 font-medium tracking-wide uppercase mb-2">
        {formatDate(event.date)}
      </p>
      <h1 class="font-serif text-4xl lg:text-5xl font-bold text-night-50 leading-tight">
        {event.title}
      </h1>
      <p class="mt-4 text-lg text-night-300">{event.description}</p>
    </header>

    <!-- Imagen del evento -->
    <EventImage
      img={event.img}
      alt={event.title}
      class=""
    />

    <!-- Grid de detalles -->
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-5 border border-night-800 rounded-sm p-6 bg-night-900/30 mb-10">
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Fecha</dt>
        <dd class="mt-1 text-night-100">{formatDate(event.date)}</dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Lugar</dt>
        <dd class="mt-1 text-night-100">{event.location}</dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Ciudad</dt>
        <dd class="mt-1 text-night-100">{event.city}</dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Formato</dt>
        <dd class="mt-1 text-night-100 capitalize">{event.format}</dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Rondas</dt>
        <dd class="mt-1 text-night-100">{event.rounds}</dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Entrada</dt>
        <dd class="mt-1 text-night-100">{formatCLP(event.entryFee)}</dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Proxies</dt>
        <dd class="mt-1 text-night-100">{proxyLabel(event.proxyesAllowed)}</dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Organizador</dt>
        <dd class="mt-1 text-night-100">{event.organizer}</dd>
      </div>
      {event.maxPlayers && (
        <div>
          <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Jugadores máx.</dt>
          <dd class="mt-1 text-night-100">{event.maxPlayers}</dd>
        </div>
      )}
    </dl>

    <!-- CTAs condicionales -->
    <div class="flex flex-wrap gap-4 mb-10">
      {isFuture && event.registrationUrl && (
        <a
          href={event.registrationUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-blood-700 hover:bg-blood-600 text-night-50 font-semibold rounded-sm transition-colors"
        >
          Inscribirse al evento ↗
        </a>
      )}
      {isPast && event.resultsUrl && (
        <a
          href={event.resultsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 border border-night-700 hover:border-night-500 text-night-200 font-semibold rounded-sm transition-colors"
        >
          Ver resultados ↗
        </a>
      )}
    </div>

    <!-- Contenido markdown -->
    {entry.body && (
      <div class="mt-10 prose prose-invert prose-sm max-w-none">
        <Content />
      </div>
    )}

    <!-- Volver -->
    <div class="mt-16 pt-8 border-t border-night-900">
      <a
        href="/events"
        class="text-sm text-blood-500 hover:text-blood-400 transition-colors"
      >
        ← Volver a eventos
      </a>
    </div>

  </div>
</BaseLayout>
