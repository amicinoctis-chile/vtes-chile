---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import BlogImage from '@/components/ui/BlogImage.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

const entry = await getEntry('blog', slug);
if (!entry || entry.data.draft) return new Response(null, { status: 404, statusText: 'Not Found' });

const post = entry.data;
const { Content } = await render(entry);

const formatDate = (s: string) =>
  new Date(s).toLocaleDateString('es-CL', { dateStyle: 'long' });
---

<BaseLayout
  title={post.title}
  description={post.description}
  ogImage={post.img ? `/images/blog/${post.img}` : undefined}
  ogType="article"
>
  <article class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-night-500">
      <a href="/blog" class="hover:text-night-300 transition-colors">Blog</a>
      <span class="mx-2">/</span>
      <span class="text-night-300">{post.title}</span>
    </nav>

    <!-- Cabecera -->
    <header class="mb-10">
      {post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {post.tags.map(tag => (
            <a
              href={`/blog?tag=${encodeURIComponent(tag)}`}
              class="text-xs text-blood-500 hover:text-blood-400 transition-colors font-medium"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
      <h1 class="font-serif text-4xl lg:text-5xl font-bold text-night-50 leading-tight">
        {post.title}
      </h1>
      <p class="mt-4 text-lg text-night-300">{post.description}</p>
      <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-night-500 border-t border-night-900 pt-6">
        <span>{post.author}</span>
        <time datetime={post.pubDate}>
          {formatDate(post.pubDate)}
        </time>
        {post.updatedDate && (
          <span>
            Actualizado: <time datetime={post.updatedDate}>{formatDate(post.updatedDate)}</time>
          </span>
        )}
      </div>
    </header>

    <!-- Imagen de portada -->
    {post.img && (
      <BlogImage
        img={post.img}
        alt={post.description}
        class="w-16 h-16 object-contain rounded-sm"
      />
    )}

    <!-- Contenido markdown -->
    <div class="prose prose-invert prose-sm max-w-none
                prose-headings:font-serif prose-headings:text-night-100
                prose-a:text-blood-500 prose-a:no-underline hover:prose-a:text-blood-400
                prose-strong:text-night-200
                prose-blockquote:border-l-blood-800 prose-blockquote:text-night-400">
      <Content />
    </div>

    <!-- Volver -->
    <div class="mt-16 pt-8 border-t border-night-900">
      <a href="/blog" class="text-sm text-blood-500 hover:text-blood-400 transition-colors">
        ← Volver al blog
      </a>
    </div>

  </article>
</BaseLayout>
