---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { env } from 'cloudflare:workers';

const turnstileSiteKey = env.TURNSTILE_SITE_KEY ?? '';

const temas = [
  'Aprender a jugar',
  'Publicar un evento, blog o deck',
  'Consultar sobre evento',
  'Borrar información',
  'Consulta general',
] as const;

const inputBase =
  'w-full bg-night-900 border border-night-700 text-marfil-100 rounded-sm px-4 py-2.5 text-sm placeholder:text-marfil-600 focus:outline-none focus:border-blood-600 transition-colors data-[invalid]:border-blood-600';
---

<BaseLayout
  title="Contacto"
  description="Contáctanos para consultas, publicaciones o cualquier tema relacionado con la comunidad VTES Chile."
>
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 py-16">

    <header class="mb-10">
      <h1 class="font-serif text-4xl font-bold text-marfil-50">Contacto</h1>
      <p class="mt-2 text-marfil-400">
        ¿Tienes preguntas, quieres publicar contenido o necesitas ayuda? Escríbenos.
      </p>
    </header>

    <!-- Estado de éxito (oculto por defecto) -->
    <div
      id="contact-success"
      hidden
      class="border border-night-700 bg-night-900/50 rounded-sm p-8 text-center"
    >
      <p class="text-lg font-semibold text-marfil-100 mb-2">¡Mensaje enviado!</p>
      <p class="text-marfil-400 text-sm mb-6">
        Gracias por escribirnos. Te responderemos a la brevedad.
      </p>
      <Button href="/" size="sm">← Volver al inicio</Button>
    </div>

    <!-- Formulario -->
    <form id="contact-form" class="flex flex-col gap-6" novalidate>

      <!-- Error global -->
      <div
        id="contact-error"
        role="alert"
        hidden
        class="border border-blood-800 bg-blood-950/30 rounded-sm px-4 py-3 text-sm text-blood-400"
      ></div>

      <!-- Nombre -->
      <div class="flex flex-col gap-1.5">
        <label for="nombre" class="text-xs text-marfil-500 font-medium uppercase tracking-wide">
          Nombre <span class="text-blood-500">*</span>
        </label>
        <input
          id="nombre"
          type="text"
          name="nombre"
          required
          autocomplete="name"
          placeholder="Tu nombre"
          class={inputBase}
        />
        <p data-error-for="nombre" hidden class="text-xs text-blood-400 mt-1"></p>
      </div>

      <!-- Correo electrónico -->
      <div class="flex flex-col gap-1.5">
        <label for="correo" class="text-xs text-marfil-500 font-medium uppercase tracking-wide">
          Correo electrónico <span class="text-blood-500">*</span>
        </label>
        <input
          id="correo"
          type="email"
          name="correo"
          required
          autocomplete="email"
          placeholder="tu@correo.com"
          class={inputBase}
        />
        <p data-error-for="correo" hidden class="text-xs text-blood-400 mt-1"></p>
      </div>

      <!-- Tema -->
      <div class="flex flex-col gap-1.5">
        <label for="tema" class="text-xs text-marfil-500 font-medium uppercase tracking-wide">
          Tema <span class="text-blood-500">*</span>
        </label>
        <select id="tema" name="tema" required class={inputBase}>
          <option value="" disabled selected>Selecciona un tema</option>
          {temas.map((t) => (
            <option value={t}>{t}</option>
          ))}
        </select>
        <p data-error-for="tema" hidden class="text-xs text-blood-400 mt-1"></p>
      </div>

      <!-- Mensaje -->
      <div class="flex flex-col gap-1.5">
        <label for="mensaje" class="text-xs text-marfil-500 font-medium uppercase tracking-wide">
          Mensaje <span class="text-blood-500">*</span>
        </label>
        <textarea
          id="mensaje"
          name="mensaje"
          required
          rows={6}
          placeholder="Escribe tu mensaje aquí..."
          class={`${inputBase} resize-y`}
        ></textarea>
        <p data-error-for="mensaje" hidden class="text-xs text-blood-400 mt-1"></p>
      </div>

      <!-- Anti-bot: honeypot + timestamp -->
      <input
        type="text"
        name="website"
        autocomplete="off"
        tabindex="-1"
        class="absolute opacity-0 pointer-events-none h-0 w-0"
      />
      <input type="hidden" name="_ts" value={Date.now()} />

      <!-- Turnstile -->
      <div
        class="cf-turnstile"
        data-sitekey={turnstileSiteKey}
        data-theme="dark"
      ></div>

      <!-- Submit -->
      <div>
        <Button type="submit" id="contact-submit">Enviar mensaje</Button>
      </div>

    </form>

  </div>

  <script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>

  <script nonce={Astro.locals.cspNonce} is:inline>
    (() => {
      const form = document.getElementById('contact-form');
      const successBox = document.getElementById('contact-success');
      const errorBox = document.getElementById('contact-error');
      const submitBtn = document.getElementById('contact-submit');
      if (!form || !successBox || !errorBox || !submitBtn) return;

      const FIELDS = ['nombre', 'correo', 'tema', 'mensaje'];

      function clearFieldErrors() {
        FIELDS.forEach((name) => {
          const input = form.querySelector(`[name="${name}"]`);
          const msg = form.querySelector(`[data-error-for="${name}"]`);
          if (input) input.removeAttribute('data-invalid');
          if (msg) {
            msg.hidden = true;
            msg.textContent = '';
          }
        });
      }

      function showFieldErrors(errors) {
        Object.entries(errors).forEach(([name, text]) => {
          const input = form.querySelector(`[name="${name}"]`);
          const msg = form.querySelector(`[data-error-for="${name}"]`);
          if (input) input.setAttribute('data-invalid', '');
          if (msg) {
            msg.textContent = String(text);
            msg.hidden = false;
          }
        });
      }

      function showGlobalError(text) {
        errorBox.textContent = text;
        errorBox.hidden = false;
      }

      function hideGlobalError() {
        errorBox.hidden = true;
        errorBox.textContent = '';
      }

      function resetTurnstile() {
        if (window.turnstile && typeof window.turnstile.reset === 'function') {
          try { window.turnstile.reset(); } catch (_) {}
        }
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        clearFieldErrors();
        hideGlobalError();

        const data = new FormData(form);
        const turnstileToken = String(data.get('cf-turnstile-response') ?? '');

        const payload = {
          nombre: String(data.get('nombre') ?? ''),
          correo: String(data.get('correo') ?? ''),
          tema: String(data.get('tema') ?? ''),
          mensaje: String(data.get('mensaje') ?? ''),
          website: String(data.get('website') ?? ''),
          _ts: Number(data.get('_ts') ?? 0),
          turnstileToken,
        };

        submitBtn.setAttribute('disabled', '');
        submitBtn.setAttribute('aria-busy', 'true');

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          let body = null;
          try { body = await res.json(); } catch (_) {}

          if (res.ok && body && body.ok) {
            form.hidden = true;
            successBox.hidden = false;
            return;
          }

          if (body && body.fieldErrors) {
            showFieldErrors(body.fieldErrors);
          }
          const msg =
            (body && body.error) ||
            `No se pudo enviar el mensaje (HTTP ${res.status}). Intenta de nuevo.`;
          showGlobalError(msg);
          resetTurnstile();
        } catch (err) {
          const detail = err && err.message ? err.message : String(err);
          showGlobalError(`Error de red: ${detail}`);
          resetTurnstile();
        } finally {
          submitBtn.removeAttribute('disabled');
          submitBtn.removeAttribute('aria-busy');
        }
      });
    })();
  </script>
</BaseLayout>
