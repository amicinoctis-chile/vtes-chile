---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import HeroSection from '@/components/HeroSection.astro';

// --- Helpers ---
const formatCLP = (n: number) =>
  n === 0
    ? 'Gratuito'
    : n.toLocaleString('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });

const formatEventDate = (dateStr: string) =>
  new Date(dateStr + 'T12:00:00').toLocaleDateString('es-CL', { dateStyle: 'long' });

const formatPostDate = (isoStr: string) =>
  new Date(isoStr).toLocaleDateString('es-CL', { dateStyle: 'medium' });

// --- Data ---
const today = new Date();
today.setHours(0, 0, 0, 0);

const upcomingEvents = (await getCollection('events'))
  .filter(e => new Date(e.data.date + 'T12:00:00') >= today)
  .sort((a, b) => a.data.date.localeCompare(b.data.date))
  .slice(0, 3);

const leagues = await getCollection('leagues');

const stores = await getCollection('stores');

const sites = (await getCollection('sites')).filter(s => s.data.active !== false);

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const latestDecks = (await getCollection('decks', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Inicio"
  description="La no oficial para la comunidad chilena de Vampire: The Eternal Struggle — eventos, ligas, decks y noticias del juego de cartas del Mundo de Tinieblas."
>

  <!-- ═══════════════════════════════════════════════════════════ HERO -->
  <HeroSection />

  <!-- ═════════════════════════════════════════════════ PRÓXIMOS EVENTOS -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 border-t border-night-900">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="font-serif text-2xl font-bold text-night-100">Próximos Eventos</h2>
      <a href="/events" class="text-sm text-blood-500 hover:text-blood-400 transition-colors">
        Ver todos →
      </a>
    </div>

    {upcomingEvents.length > 0 ? (
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {upcomingEvents.map(event => (
          <li class="border border-night-800 bg-night-900/50 p-5 rounded-sm hover:border-blood-800 transition-colors">
            <time
              datetime={event.data.date}
              class="text-xs text-blood-500 font-medium tracking-wide uppercase"
            >
              {formatEventDate(event.data.date)}
            </time>
            <h3 class="mt-2 text-night-100 font-semibold">{event.data.title}</h3>
            <p class="mt-1 text-sm text-night-400 capitalize">
              {event.data.city} · {event.data.format}
            </p>
            <p class="mt-2 text-sm font-medium text-gold-500">
              {formatCLP(event.data.entryFee)}
            </p>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-night-500 text-sm">No hay eventos próximos por el momento.</p>
    )}
  </section>

  <!-- ═══════════════════════════════════════════════════════════ LIGAS -->
  {leagues.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 border-t border-night-900">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-serif text-2xl font-bold text-night-100">Ligas</h2>
        <a href="/ligas" class="text-sm text-blood-500 hover:text-blood-400 transition-colors">
          Ver todas →
        </a>
      </div>
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {leagues.map(league => (
          <li class="border border-night-800 bg-night-900/50 p-5 rounded-sm hover:border-blood-800 transition-colors">
            <h3 class="text-night-100 font-semibold">{league.data.title}</h3>
            <p class="mt-1 text-sm text-night-400">
              {league.data.city} · {league.data.day} {league.data.hour}
            </p>
            <p class="mt-1 text-sm text-night-400 capitalize">
              {league.data.format} · Proxies: {league.data.proxyesAllowed}
            </p>
            <p class="mt-2 text-sm font-medium text-gold-500">
              {formatCLP(league.data.entryFee)}
            </p>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- ══════════════════════════════════════════════════════════ TIENDAS -->
  {stores.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 border-t border-night-900">
      <h2 class="font-serif text-2xl font-bold text-night-100 mb-8">Tiendas</h2>
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {stores.map(store => (
          <li class="border border-night-800 bg-night-900/50 p-5 rounded-sm">
            <h3 class="text-night-100 font-semibold">{store.data.name}</h3>
            <p class="mt-1 text-sm text-night-400">{store.data.location}</p>
            <p class="text-xs text-night-500">{store.data.city}</p>
            <div class="mt-3 flex flex-col gap-1">
              {store.data.url && (
                <a
                  href={store.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs text-blood-500 hover:text-blood-400 transition-colors"
                >
                  Sitio web ↗
                </a>
              )}
              {store.data.instagram && (
                <a
                  href={store.data.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs text-blood-500 hover:text-blood-400 transition-colors"
                >
                  Instagram ↗
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════ SITIOS -->
  {sites.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 border-t border-night-900">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-serif text-2xl font-bold text-night-100">Comunidad</h2>
        <a href="/comunidad" class="text-sm text-blood-500 hover:text-blood-400 transition-colors">
          Ver todos →
        </a>
      </div>
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {sites.map(site => (
          <li class="border border-night-800 bg-night-900/50 p-5 rounded-sm hover:border-blood-800 transition-colors">
            <span class="text-xs text-night-500 font-medium tracking-wide uppercase">
              {site.data.platform}
            </span>
            <h3 class="mt-1 text-night-100 font-semibold">{site.data.name}</h3>
            <p class="mt-1 text-sm text-night-400">{site.data.description}</p>
            {site.data.url && (
              <a
                href={site.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 inline-block text-xs text-blood-500 hover:text-blood-400 transition-colors"
              >
                Visitar ↗
              </a>
            )}
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- ════════════════════════════════════════════════════════════ BLOG -->
  {latestPosts.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 border-t border-night-900">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-serif text-2xl font-bold text-night-100">Últimas Noticias</h2>
        <a href="/blog" class="text-sm text-blood-500 hover:text-blood-400 transition-colors">
          Ver todas →
        </a>
      </div>
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {latestPosts.map(post => (
          <li class="group">
            <a
              href={`/blog/${post.id}`}
              class="block border border-night-800 bg-night-900/30 p-5 rounded-sm hover:border-blood-800 transition-colors"
            >
              <time
                datetime={post.data.pubDate}
                class="text-xs text-night-500"
              >
                {formatPostDate(post.data.pubDate)}
              </time>
              <h3 class="mt-2 text-night-100 font-semibold group-hover:text-blood-400 transition-colors">
                {post.data.title}
              </h3>
              <p class="mt-2 text-sm text-night-400 line-clamp-2">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════ DECKS -->
  {latestDecks.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 border-t border-night-900">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-serif text-2xl font-bold text-night-100">Decks</h2>
        <a href="/decks" class="text-sm text-blood-500 hover:text-blood-400 transition-colors">
          Ver todos →
        </a>
      </div>
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {latestDecks.map(deck => (
          <li class="group">
            <a
              href={`/decks/${deck.id}`}
              class="block border border-night-800 bg-night-900/30 p-5 rounded-sm hover:border-blood-800 transition-colors"
            >
              <span class="text-xs text-night-500 font-medium tracking-wide uppercase">
                {deck.data.format}
              </span>
              <h3 class="mt-1 text-night-100 font-semibold group-hover:text-blood-400 transition-colors">
                {deck.data.title}
              </h3>
              <p class="mt-2 text-xs text-night-400">
                <span class="text-night-500">Clan:</span> {deck.data.clan.join(', ')}
              </p>
              <p class="text-xs text-night-400">
                <span class="text-night-500">Disciplinas:</span> {deck.data.discipline.join(', ')}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

</BaseLayout>
