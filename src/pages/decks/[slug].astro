---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/decks');

const entry = await getEntry('decks', slug);
if (!entry) return new Response(null, { status: 404, statusText: 'Not Found' });

const deck = entry.data;
const { Content } = await render(entry);

const formatDate = (s: string) =>
  new Date(s).toLocaleDateString('es-CL', { dateStyle: 'long' });
---

<BaseLayout
  title={deck.title}
  description={deck.description}
  ogType="article"
>
  <article class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-night-500">
      <a href="/decks" class="hover:text-night-300 transition-colors">Decks</a>
      <span class="mx-2">/</span>
      <span class="text-night-300">{deck.title}</span>
    </nav>

    <!-- Cabecera -->
    <header class="mb-10">
      {deck.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {deck.tags.map(tag => (
            <a
              href={`/decks?tag=${encodeURIComponent(tag)}`}
              class="text-xs text-blood-500 hover:text-blood-400 transition-colors font-medium"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
      <div class="mb-2">
        <span class="text-xs text-night-500 border border-night-700 rounded-sm px-2 py-0.5 font-medium uppercase">
          {deck.format}
        </span>
      </div>
      <h1 class="font-serif text-4xl lg:text-5xl font-bold text-night-50 leading-tight">
        {deck.title}
      </h1>
      <p class="mt-4 text-lg text-night-300">{deck.description}</p>
      <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-night-500 border-t border-night-900 pt-6">
        <span>Por {deck.author}</span>
        <time datetime={deck.pubDate}>{formatDate(deck.pubDate)}</time>
      </div>
    </header>

    <!-- Grid de detalles -->
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-5 border border-night-800 rounded-sm p-6 bg-night-900/30 mb-10">
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Formato</dt>
        <dd class="mt-1 text-night-100">{deck.format}</dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Clan</dt>
        <dd class="mt-1 text-night-100">{deck.clan.length > 0 ? deck.clan.join(', ') : '—'}</dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Disciplinas</dt>
        <dd class="mt-1 text-night-100">{deck.discipline.length > 0 ? deck.discipline.join(', ') : '—'}</dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Publicado</dt>
        <dd class="mt-1 text-night-100"><time datetime={deck.pubDate}>{formatDate(deck.pubDate)}</time></dd>
      </div>
      <div>
        <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Autor</dt>
        <dd class="mt-1 text-night-100">{deck.author}</dd>
      </div>
      {deck.comments && (
        <div class="sm:col-span-2">
          <dt class="text-xs text-night-500 font-medium uppercase tracking-wide">Notas</dt>
          <dd class="mt-1 text-night-300 text-sm">{deck.comments}</dd>
        </div>
      )}
    </dl>

    <!-- CTA externo -->
    {deck.url && (
      <div class="mb-10">
        <a
          href={deck.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-blood-700 hover:bg-blood-600 text-night-50 font-semibold rounded-sm transition-colors"
        >
          Ver deck completo ↗
        </a>
      </div>
    )}

    <!-- Contenido markdown -->
    {entry.body && (
      <div class="prose prose-invert prose-sm max-w-none
                  prose-headings:font-serif prose-headings:text-night-100
                  prose-a:text-blood-500 prose-a:no-underline hover:prose-a:text-blood-400
                  prose-strong:text-night-200
                  prose-blockquote:border-l-blood-800 prose-blockquote:text-night-400">
        <Content />
      </div>
    )}

    <!-- Volver + filtros rápidos -->
    <div class="mt-16 pt-8 border-t border-night-900 flex flex-wrap items-center justify-between gap-4">
      <a href="/decks" class="text-sm text-blood-500 hover:text-blood-400 transition-colors">
        ← Volver a decks
      </a>
      <div class="flex flex-wrap gap-2">
        {deck.clan.map(c => (
          <a
            href={`/decks?clan=${encodeURIComponent(c)}`}
            class="text-xs text-night-500 border border-night-800 rounded-sm px-2 py-0.5 hover:border-night-600 hover:text-night-300 transition-colors"
          >
            {c}
          </a>
        ))}
        {deck.discipline.map(d => (
          <a
            href={`/decks?disciplina=${encodeURIComponent(d)}`}
            class="text-xs text-night-500 border border-night-800 rounded-sm px-2 py-0.5 hover:border-night-600 hover:text-night-300 transition-colors"
          >
            {d}
          </a>
        ))}
      </div>
    </div>

  </article>
</BaseLayout>
